# =============================================================================
# Enzine — единый формат переменных окружения (копировать в .env в корне репо)
# =============================================================================

# --- Telegram Bot ---
BOT_TOKEN=
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=
BOT_WEBHOOK_PATH=/webhook
BOT_PORT=3000

# --- Mini App (Next.js) ---
NEXT_PUBLIC_BOT_USERNAME=
NEXT_PUBLIC_API_URL=http://localhost:3000
MINIAPP_PORT=3001

# --- Database ---
DATABASE_URL=postgresql://enzine:enzine@localhost:5432/enzine

# --- Runtime ---
NODE_ENV=development

# =============================================================================
# Локально: оставьте BOT_WEBHOOK_URL пустым → long polling
# Production (Fly.io): BOT_WEBHOOK_URL=https://ваш-app.fly.dev/webhook
# =============================================================================
